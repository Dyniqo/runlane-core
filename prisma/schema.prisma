generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspacePlan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum WorkspaceMemberRole {
  OWNER
  MEMBER
}

model User {
  id                   String            @id @default(uuid()) @db.Uuid
  email                String            @unique(map: "users_email_key") @db.VarChar(320)
  passwordHash         String            @map("password_hash") @db.VarChar(255)
  name                 String            @db.VarChar(120)
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)
  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  sessions             Session[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(128)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  ip               String?   @db.VarChar(64)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(3)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(3)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, revokedAt], map: "sessions_user_id_revoked_at_idx")
  @@index([expiresAt], map: "sessions_expires_at_idx")
  @@map("sessions")
}

model Workspace {
  id        String            @id @default(uuid()) @db.Uuid
  name      String            @db.VarChar(120)
  ownerId   String            @map("owner_id") @db.Uuid
  plan      WorkspacePlan     @default(FREE)
  isDemo    Boolean           @default(false) @map("is_demo")
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)
  owner     User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  members   WorkspaceMember[]

  @@index([ownerId], map: "workspaces_owner_id_idx")
  @@index([id, ownerId], map: "workspaces_id_owner_id_idx")
  @@map("workspaces")
}

model WorkspaceMember {
  id          String              @id @default(uuid()) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  role        WorkspaceMemberRole @default(MEMBER)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([workspaceId, userId], map: "workspace_members_workspace_id_user_id_key")
  @@index([userId], map: "workspace_members_user_id_idx")
  @@index([workspaceId, role], map: "workspace_members_workspace_id_role_idx")
  @@index([userId, workspaceId, role], map: "workspace_members_user_id_workspace_id_role_idx")
  @@map("workspace_members")
}
