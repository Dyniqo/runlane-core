generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspacePlan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum WorkspaceMemberRole {
  OWNER
  MEMBER
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WebhookRequestStatus {
  ACCEPTED
  REJECTED
}

enum ExecutionStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  RETRYING
  DEAD_LETTER
  CANCELLED
}

enum ExecutionStepStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

enum UsageMetricType {
  EXECUTION
  AI_CALL
  HTTP_CALL
  WEBHOOK_REQUEST
  RETRY
}

enum BillingProvider {
  STRIPE
}

enum BillingEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum BillingStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

model User {
  id                   String            @id @default(uuid()) @db.Uuid
  email                String            @unique(map: "users_email_key") @db.VarChar(320)
  passwordHash         String            @map("password_hash") @db.VarChar(255)
  name                 String            @db.VarChar(120)
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)
  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  sessions             Session[]
  auditLogs            AuditLog[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(128)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  ip               String?   @db.VarChar(64)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(3)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(3)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, revokedAt], map: "sessions_user_id_revoked_at_idx")
  @@index([expiresAt], map: "sessions_expires_at_idx")
  @@map("sessions")
}

model Workspace {
  id        String            @id @default(uuid()) @db.Uuid
  name      String            @db.VarChar(120)
  ownerId   String            @map("owner_id") @db.Uuid
  plan      WorkspacePlan     @default(FREE)
  stripeCustomerId           String?       @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId       String?       @map("stripe_subscription_id") @db.VarChar(255)
  billingStatus             BillingStatus @default(NONE) @map("billing_status")
  billingCurrentPeriodStart DateTime?     @map("billing_current_period_start") @db.Timestamptz(3)
  billingCurrentPeriodEnd   DateTime?     @map("billing_current_period_end") @db.Timestamptz(3)
  isDemo    Boolean           @default(false) @map("is_demo")
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)
  owner     User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  members   WorkspaceMember[]
  apiKeys   ApiKey[]
  auditLogs AuditLog[]
  workflows       Workflow[]
  webhookRequests WebhookRequest[]
  executions      Execution[]
  executionSteps  ExecutionStep[]
  workflowSecrets WorkflowSecret[]
  connectorCredentials ConnectorCredential[]
  usageRecords UsageRecord[]
  billingEvents BillingEvent[]
  demoState DemoState?

  @@index([ownerId], map: "workspaces_owner_id_idx")
  @@index([stripeCustomerId], map: "workspaces_stripe_customer_id_idx")
  @@index([stripeSubscriptionId], map: "workspaces_stripe_subscription_id_idx")
  @@index([id, ownerId], map: "workspaces_id_owner_id_idx")
  @@index([isDemo, createdAt], map: "workspaces_is_demo_created_at_idx")
  @@map("workspaces")
}

model DemoState {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @unique(map: "demo_states_workspace_id_key") @map("workspace_id") @db.Uuid
  seedVersion String    @map("seed_version") @db.VarChar(80)
  resetAt     DateTime  @map("reset_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([resetAt], map: "demo_states_reset_at_idx")
  @@map("demo_states")
}

model WorkspaceMember {
  id          String              @id @default(uuid()) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  role        WorkspaceMemberRole @default(MEMBER)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([workspaceId, userId], map: "workspace_members_workspace_id_user_id_key")
  @@index([userId], map: "workspace_members_user_id_idx")
  @@index([workspaceId, role], map: "workspace_members_workspace_id_role_idx")
  @@index([userId, workspaceId, role], map: "workspace_members_user_id_workspace_id_role_idx")
  @@map("workspace_members")
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String    @db.VarChar(120)
  prefix      String    @unique(map: "api_keys_prefix_key") @db.VarChar(32)
  keyHash     String    @map("key_hash") @db.VarChar(255)
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(3)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([workspaceId, id], map: "api_keys_workspace_id_id_idx")
  @@index([workspaceId, prefix], map: "api_keys_workspace_id_prefix_idx")
  @@index([workspaceId, revokedAt, createdAt], map: "api_keys_workspace_id_revoked_at_created_at_idx")
  @@map("api_keys")
}


model AuditLog {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  actorUserId  String?   @map("actor_user_id") @db.Uuid
  action       String    @db.VarChar(96)
  entityType   String    @map("entity_type") @db.VarChar(64)
  entityId     String?   @map("entity_id") @db.VarChar(128)
  metadataJson Json      @default("{}") @map("metadata_json")
  ip           String?   @db.VarChar(64)
  userAgent    String?   @map("user_agent") @db.VarChar(512)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actorUser    User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([workspaceId, createdAt, id], map: "audit_logs_workspace_id_created_at_id_idx")
  @@index([workspaceId, action, createdAt], map: "audit_logs_workspace_id_action_created_at_idx")
  @@index([workspaceId, entityType, entityId], map: "audit_logs_workspace_id_entity_type_entity_id_idx")
  @@index([actorUserId, createdAt], map: "audit_logs_actor_user_id_created_at_idx")
  @@map("audit_logs")
}


model Workflow {
  id             String         @id @default(uuid()) @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  publicId       String         @unique(map: "workflows_public_id_key") @map("public_id") @db.VarChar(40)
  name           String         @db.VarChar(140)
  status         WorkflowStatus @default(DRAFT)
  version        Int            @default(1)
  definitionJson Json           @default("{}") @map("definition_json")
  triggerType    String         @default("webhook") @map("trigger_type") @db.VarChar(64)
  publishedAt    DateTime?      @map("published_at") @db.Timestamptz(3)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  webhookRequests WebhookRequest[]
  executions      Execution[]
  secrets         WorkflowSecret[]
  connectorCredentials ConnectorCredential[]

  @@index([workspaceId, id], map: "workflows_workspace_id_id_idx")
  @@index([workspaceId, publicId], map: "workflows_workspace_id_public_id_idx")
  @@index([workspaceId, status, updatedAt], map: "workflows_workspace_id_status_updated_at_idx")
  @@index([workspaceId, createdAt, id], map: "workflows_workspace_id_created_at_id_idx")
  @@map("workflows")
}

model WebhookRequest {
  id             String               @id @default(uuid()) @db.Uuid
  workspaceId    String               @map("workspace_id") @db.Uuid
  workflowId     String               @map("workflow_id") @db.Uuid
  signature      String?              @db.VarChar(512)
  idempotencyKey String?              @map("idempotency_key") @db.VarChar(160)
  payloadHash    String               @map("payload_hash") @db.VarChar(64)
  source         String               @db.VarChar(80)
  ip             String?              @db.VarChar(64)
  userAgent      String?              @map("user_agent") @db.VarChar(512)
  status         WebhookRequestStatus @default(ACCEPTED)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workflow       Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([workspaceId, id], map: "webhook_requests_workspace_id_id_idx")
  @@index([workspaceId, workflowId, createdAt], map: "webhook_requests_workspace_id_workflow_id_created_at_idx")
  @@index([workspaceId, idempotencyKey], map: "webhook_requests_workspace_id_idempotency_key_idx")
  @@index([workflowId, createdAt], map: "webhook_requests_workflow_id_created_at_idx")
  @@map("webhook_requests")
}


model ExecutionStep {
  id           String              @id @default(uuid()) @db.Uuid
  workspaceId  String              @map("workspace_id") @db.Uuid
  executionId  String              @map("execution_id") @db.Uuid
  stepKey      String              @map("step_key") @db.VarChar(80)
  type         String              @db.VarChar(64)
  status       ExecutionStepStatus @default(RUNNING)
  inputJson    Json                @map("input_json")
  outputJson   Json?               @map("output_json")
  errorCode    String?             @map("error_code") @db.VarChar(96)
  errorMessage String?             @map("error_message") @db.Text
  durationMs   Int?                @map("duration_ms")
  startedAt    DateTime            @map("started_at") @db.Timestamptz(3)
  finishedAt   DateTime?           @map("finished_at") @db.Timestamptz(3)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  execution    Execution           @relation(fields: [executionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([workspaceId, executionId, stepKey], map: "execution_steps_workspace_id_execution_id_step_key_key")
  @@index([workspaceId, executionId], map: "execution_steps_workspace_id_execution_id_idx")
  @@index([workspaceId, status, startedAt], map: "execution_steps_workspace_id_status_started_at_idx")
  @@index([executionId, startedAt], map: "execution_steps_execution_id_started_at_idx")
  @@map("execution_steps")
}

model Execution {
  id           String          @id @default(uuid()) @db.Uuid
  workspaceId  String          @map("workspace_id") @db.Uuid
  workflowId   String          @map("workflow_id") @db.Uuid
  status       ExecutionStatus @default(QUEUED)
  inputJson    Json            @map("input_json")
  outputJson   Json?           @map("output_json")
  errorCode    String?         @map("error_code") @db.VarChar(96)
  errorMessage String?         @map("error_message") @db.Text
  attempts     Int             @default(0)
  durationMs   Int?            @map("duration_ms")
  queuedAt     DateTime        @default(now()) @map("queued_at") @db.Timestamptz(3)
  startedAt    DateTime?       @map("started_at") @db.Timestamptz(3)
  finishedAt   DateTime?       @map("finished_at") @db.Timestamptz(3)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workflow     Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  steps        ExecutionStep[]

  @@index([workspaceId, id], map: "executions_workspace_id_id_idx")
  @@index([workspaceId, workflowId], map: "executions_workspace_id_workflow_id_idx")
  @@index([workspaceId, status, createdAt], map: "executions_workspace_id_status_created_at_idx")
  @@index([workflowId, createdAt], map: "executions_workflow_id_created_at_idx")
  @@map("executions")
}

model UsageRecord {
  id           String          @id @default(uuid()) @db.Uuid
  workspaceId  String          @map("workspace_id") @db.Uuid
  type         UsageMetricType
  quantity     Int             @default(1)
  sourceType   String          @map("source_type") @db.VarChar(64)
  sourceId     String          @map("source_id") @db.VarChar(160)
  metadataJson Json            @default("{}") @map("metadata_json")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([workspaceId, type, sourceType, sourceId], map: "usage_records_workspace_id_type_source_type_source_id_key")
  @@index([workspaceId, type, createdAt], map: "usage_records_workspace_id_type_created_at_idx")
  @@index([workspaceId, createdAt, id], map: "usage_records_workspace_id_created_at_id_idx")
  @@map("usage_records")
}

model BillingEvent {
  id              String             @id @default(uuid()) @db.Uuid
  workspaceId     String?            @map("workspace_id") @db.Uuid
  provider        BillingProvider
  providerEventId String             @map("provider_event_id") @db.VarChar(255)
  eventType       String             @map("event_type") @db.VarChar(120)
  status          BillingEventStatus @default(RECEIVED)
  payloadJson     Json               @map("payload_json")
  errorMessage    String?            @map("error_message") @db.Text
  receivedAt      DateTime           @map("received_at") @db.Timestamptz(3)
  processedAt     DateTime?          @map("processed_at") @db.Timestamptz(3)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  workspace       Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([provider, providerEventId], map: "billing_events_provider_provider_event_id_key")
  @@index([workspaceId, receivedAt], map: "billing_events_workspace_id_received_at_idx")
  @@index([provider, status, receivedAt], map: "billing_events_provider_status_received_at_idx")
  @@map("billing_events")
}

model WorkflowSecret {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  workflowId     String   @map("workflow_id") @db.Uuid
  key            String   @db.VarChar(128)
  encryptedValue String   @map("encrypted_value") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workflow       Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([workspaceId, workflowId, key], map: "workflow_secrets_workspace_id_workflow_id_key_key")
  @@index([workspaceId, workflowId], map: "workflow_secrets_workspace_id_workflow_id_idx")
  @@index([workspaceId, key], map: "workflow_secrets_workspace_id_key_idx")
  @@map("workflow_secrets")
}

model ConnectorCredential {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  workflowId     String   @map("workflow_id") @db.Uuid
  name           String   @db.VarChar(120)
  type           String   @db.VarChar(64)
  encryptedValue String   @map("encrypted_value") @db.Text
  metadataJson   Json     @default("{}") @map("metadata_json")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workflow       Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([workspaceId, workflowId, name], map: "connector_credentials_workspace_id_workflow_id_name_key")
  @@index([workspaceId, workflowId], map: "connector_credentials_workspace_id_workflow_id_idx")
  @@index([workspaceId, type, createdAt], map: "connector_credentials_workspace_id_type_created_at_idx")
  @@map("connector_credentials")
}
